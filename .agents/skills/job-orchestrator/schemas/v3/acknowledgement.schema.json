{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worker acknowledgement v3",
  "type": "object",
  "required": ["schema_version", "protocol_version", "protocol_sha256", "job_id", "contract_revision", "current_workflow_node_id", "acknowledged_at"],
  "properties": {
    "schema_version": {"const": 3},
    "protocol_version": {"const": 3},
    "protocol_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "job_id": {"type": "string", "minLength": 1},
    "contract_revision": {"type": "integer", "minimum": 1},
    "current_workflow_node_id": {"type": "string", "minLength": 1},
    "acknowledged_at": {"type": "string", "format": "date-time"},
    "session_id": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
