{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worker progress v3",
  "type": "object",
  "required": ["schema_version", "dispatch_id", "nonce", "phase", "completed_work_units", "checkpoint_sha256", "updated_at", "checkpoint"],
  "properties": {
    "schema_version": {"const": 3},
    "dispatch_id": {"type": "string", "minLength": 1},
    "nonce": {"type": "string", "minLength": 1},
    "phase": {"type": "string", "minLength": 1},
    "completed_work_units": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "checkpoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "updated_at": {"type": "string", "format": "date-time"},
    "checkpoint": {"type": "object"}
  },
  "additionalProperties": false
}
