{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unresolved action v3",
  "type": "object",
  "required": ["schema_version", "action_id", "type", "run_id", "job_id", "status", "correlation_id", "created_at", "prompt"],
  "properties": {
    "schema_version": {"const": 3},
    "action_id": {"type": "string", "minLength": 1},
    "type": {"enum": ["spawn_and_bootstrap", "send_dispatch", "wait", "request_status", "route_resolution", "ask_user", "run_complete", "reconcile_result", "record_recovered_result"]},
    "run_id": {"type": "string", "minLength": 1},
    "job_id": {"type": ["string", "null"]},
    "status": {"enum": ["unresolved", "resolved"]},
    "correlation_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "prompt": {"type": ["string", "null"]},
    "dispatch_id": {"type": "string", "minLength": 1},
    "replacement": {"type": "boolean"},
    "child_reports": {"type": "array", "items": {"type": "object"}},
    "child_request_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "response_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
