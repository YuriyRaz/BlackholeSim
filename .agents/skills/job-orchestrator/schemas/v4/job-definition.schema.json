{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job registration definition v4",
  "type": "object",
  "required": ["schema_version", "jobs"],
  "properties": {
    "schema_version": {"type": "integer", "const": 4},
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "goal", "completion_conditions", "report_required"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "goal": {"type": "string", "minLength": 1},
          "workflow": {"type": ["string", "null"], "minLength": 1},
          "requirements": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "constraints": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "completion_conditions": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "context": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "escalation": {"type": "string", "minLength": 1},
          "report_required": {"type": "boolean"},
          "priority": {"type": "integer"},
          "depends_on": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "parent_job_id": {"type": ["string", "null"], "minLength": 1},
          "related_reports": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "recovery_policy": {
            "type": ["object", "null"],
            "required": ["effect", "check"],
            "properties": {
              "effect": {"type": "string", "enum": ["repository", "external_non_idempotent"]},
              "check": {
                "type": "string",
                "minLength": 1,
                "description": "Method-agnostic check for whether the effect occurred; perform it outside jobctl and supply its result as recovery evidence before retry."
              },
              "idempotency_key": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
